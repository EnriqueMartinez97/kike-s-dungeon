{
  "name": "User",
  "type": "object",
  "properties": {
    "display_name": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string"
    },
    "timezone": {
      "type": "string",
      "default": "UTC"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    }
  },
  "required": [
    "display_name",
    "avatar_url"
  ]
}